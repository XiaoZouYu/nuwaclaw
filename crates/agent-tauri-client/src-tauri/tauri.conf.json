{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SantiClaw",
  "mainBinaryName": "agent-tauri-client",
  "version": "../package.json",
  "identifier": "com.santisaas.santiclaw-tauri-client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "三体大龙虾",
        "width": 960,
        "height": 640
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "externalBin": [
      "binaries/nuwax-lanproxy",
      "binaries/mcp-proxy",
      "binaries/node-runtime"
    ],
    "resources": [
      "resources/node/bin/",
      "resources/node/lib/",
      "resources/uv/bin/"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIyMTczQzJDQzE1MkYwMzgKUldRNDhGTEJMRHdYSWdiTXlROWtiVTBhcGhCQUlhczRqMTZCMTN0YUhtNTg0eFBFbW5qUnZmSVMK",
      "endpoints": [
        "https://santisaas.oss-cn-chengdu.aliyuncs.com/santiclaw-tauri-client/latest/latest.json",
        "https://github.com/XiaoZouYu/nuwaclaw/releases/latest/download/latest.json"
      ]
    },
    "cli": {
      "description": "SantiClaw Desktop Client - 智能 Agent 桌面客户端",
      "args": [
        {
          "name": "tab",
          "description": "指定启动后跳转的 Tab 页面",
          "short": "t",
          "takesValue": true
        },
        {
          "name": "minimized",
          "description": "启动时最小化到系统托盘",
          "short": "m",
          "takesValue": false
        }
      ]
    }
  }
}
